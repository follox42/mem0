# === OpenAI ===
# Used for: fact extraction (gpt-4o-mini), embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# === Postgres (metadata: users, apps, ACL, history) ===
POSTGRES_PASSWORD=changeme

# === Neo4j (graph memory) ===
# Auto-detected by api/app/utils/memory.py if set.
# Browser UI on :7474, Bolt on :7687.
NEO4J_PASSWORD=changeme

# === OpenMemory mode ===
# Empty (default) = multi-user mode: users created on-the-fly from MCP path.
# Set to a single user_id (e.g. "nolann") for legacy single-user mode.
USER=

# Run scripts/seed.py at boot (idempotent: reads config/*.yaml)
SEED_ON_BOOT=true

# Optional API key for protecting REST endpoints
API_KEY=

# === UI ===
# Public URL of the API (used by the Next.js UI build)
NEXT_PUBLIC_API_URL=http://localhost:8765
